APP_NAME=A5 Scenic Guide AI
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=sqlite:///./app.db
FAQ_DATA_PATH=../data/processed/faq_entries.json
DEFAULT_KNOWLEDGE_SOURCE=official_data_pack
CHROMA_PERSIST_DIR=../kb/chroma_db
MODEL_CACHE_DIR=../.cache/huggingface
RAG_COLLECTION_NAME=scenic_knowledge_chunks
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
FAQ_SEMANTIC_THRESHOLD=0.60
RERANKER_MODEL_NAME=BAAI/bge-reranker-base
RERANKER_BATCH_SIZE=8
RERANKER_MAX_LENGTH=512
RAG_CANDIDATE_K=20
RAG_TOP_K=5
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=512
LLM_CONNECT_TIMEOUT_SECONDS=5
LLM_FIRST_TOKEN_TIMEOUT_SECONDS=15
LLM_READ_TIMEOUT_SECONDS=20
LLM_TOTAL_TIMEOUT_SECONDS=45
LLM_MAX_CONCURRENCY=4
LLM_MAX_EVIDENCE_DOCUMENTS=5
LLM_MAX_EVIDENCE_CHARS_PER_DOCUMENT=1800

# Vision model provider. Keep image recognition as retrieval hints only.
VISION_PROVIDER=stub
VISION_API_KEY=
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen3.7-plus
VISION_READ_TIMEOUT_SECONDS=60
VISION_TOTAL_TIMEOUT_SECONDS=90
VISION_MAX_IMAGE_BYTES=5242880
CACHE_TTL_SECONDS=604800
ENABLE_SAMPLE_DATA=true

# ASR (Speech-to-Text) Configuration
# Provider: "stub" (placeholder), "bailian" (Paraformer via DashScope async task),
#           "qwen" (Qwen3-ASR-Flash via OpenAI-compatible endpoint, supports 52 dialects)
ASR_PROVIDER=qwen
ASR_API_KEY=
ASR_MODEL=qwen3-asr-flash
ASR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/audio/transcriptions
# Only used by bailian provider (legacy):
ASR_TASK_URL=https://dashscope.aliyuncs.com/api/v1/tasks
# Optional Bailian hot-word vocabulary id. Create it in Model Studio first.
ASR_VOCABULARY_ID=
# LingShan hotwords for ASR accuracy improvement (comma-separated)
ASR_HOTWORDS=灵山大佛,九龙灌浴,灵山梵宫,五印坛城,祥符禅寺,拈花堂
# Required for Bailian recorded-speech ASR because the cloud task pulls audio by URL.
# Example after deployment or tunnel: https://your-public-domain.example.com
# NOT needed for qwen provider, which accepts raw audio bytes directly.
ASR_PUBLIC_AUDIO_BASE_URL=
ASR_UPLOAD_DIR=../.uploads/asr
ASR_TIMEOUT_SECONDS=30
ASR_POLL_INTERVAL_SECONDS=0.8
ASR_MAX_AUDIO_BYTES=10485760

# TTS (Text-to-Speech) Configuration
TTS_PROVIDER=bailian
# Native CosyVoice requires a standard regional DashScope API key.
# Workspace keys beginning with sk-ws- may only work with compatible-mode APIs.
TTS_API_KEY=
TTS_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/audio/tts/SpeechSynthesizer
TTS_MODEL=cosyvoice-v3-flash
TTS_VOICE=longwan_v3
TTS_TIMEOUT_SECONDS=30

# Live data and dynamic route planning
LIVE_DATA_PROVIDER=mock
LIVE_DATA_MOCK_WEATHER=晴
LIVE_DATA_MOCK_TEMPERATURE=22-28°C
LIVE_DATA_MOCK_CROWD_LEVEL=中等
COZE_ENABLED=false
COZE_RUN_URL=
COZE_TOKEN=
COZE_TIMEOUT_SECONDS=12

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Admin authentication
ADMIN_PASSWORD=admin123
ADMIN_TOKEN_SECRET=a5-scenic-admin-secret-key
